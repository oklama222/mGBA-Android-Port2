<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <com.example.mgbalink.EmulatorView
        android:id="@+id/emulatorView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.example.mgbalink.TouchControlsView
        android:id="@+id/touchControlsView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!--
        Single small menu button at the TOP-CENTER of the screen.
        Positioned between the L and R shoulder buttons so it does not
        overlap either. Tapping it opens a popup menu.
    -->
    <Button
        android:id="@+id/btnMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="4dp"
        android:alpha="0.6"
        android:text="@string/emu_menu"
        android:textSize="12sp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

</FrameLayout>
